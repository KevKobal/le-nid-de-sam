# Photos originales (plusieurs Mo chacune) : seules les versions optimisées
# du dossier img/ servent au site. Les originaux restent en local.
IMG_*.jpeg
IMG_*.JPEG
IMG_*.jpg
# Original haute résolution de la photo Moselle (~26 Mo) : seule img/moselle.jpg
# (optimisée) est publiée.
img/paysage moselle.JPG

# Vidéo source en 4K (~200 Mo) : trop lourde pour GitHub (limite 100 Mo) et
# pour le web. Seule la version optimisée video/paysage.mp4 est publiée.
niddesam.mp4
*.mov
*.MOV

# macOS
.DS_Store

# Configuration locale de l'éditeur : contient des chemins propres à la machine
# (dossier de prévisualisation), sans intérêt pour le site publié.
.claude/
